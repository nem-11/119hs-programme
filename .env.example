# Copy to ".env" at the repo root for local development (never commit .env).

# --- Server (Render Web Service or local) ---
NODE_ENV=development
PORT=3001

# Required in production: strong random string for JWT signing
JWT_SECRET=replace-with-long-random-secret

# SQLite file (relative paths resolve from process.cwd(), usually the repo root)
DATABASE_PATH=./data/119hs.db
# If you still have the old database at server/119hs.db, point there until you move it:
# DATABASE_PATH=./server/119hs.db

# Required on first production boot when the database has no users (empty volume). Not logged to console.
# SEED_ADMIN_PASSWORD=your-secure-initial-password

# CORS: browser origin(s) allowed to call the API. Comma-separate for multiple, e.g. app + www.
# Same single service: set to your public site URL. Render also adds RENDER_EXTERNAL_URL when applicable.
FRONTEND_URL=https://your-app.onrender.com

# Anthropic (natural language programme commands — optional; leave unset to disable / error only when feature is used)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Client build-time (create-react-app; prefix REACT_APP_) ---
# Leave empty when the API is served from the same origin as the static app (typical single Render service).
# Set to full API origin when the SPA is hosted separately, e.g. https://api-your-app.onrender.com
REACT_APP_API_URL=
